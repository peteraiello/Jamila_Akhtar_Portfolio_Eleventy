<section class="quick-links {{ "bg-" + (quickLinks.backgroundColour or "white") }}"">
    <div class="container">
        {% if quickLinks.title %}
            <h3>{{ quickLinks.title }}</h3>
        {% endif %}
        <div class="grid">
            <div class="cards-wrapper">
                {%- for card in quickLinks.cards -%}
                    {% set cardImage = card.image.src %}
                    {% set cardImageAlt = card.image.altText %}
                    {% set cardTitle = card.title %}
                    {% set cardBlurb = card.blurb %}      
                    {% set cardLink = card.button.link %}
                    {% set cardTheme = card.theme %}
                    {% set cardButtonTheme = card.button.theme %}  
                    {% set cardButtonText = card.button.text %} 
                    {% include "../components/card.njk" %}
                {%- endfor -%}
            </div>
        </div>
    </div>
</section>